{
    "name": "navifox-pages",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev:www": "pnpm --filter @navifox/www run dev --host",
        "dev:docs": "pnpm --filter @navifox/docs run dev --host",
        "build": "pnpm -r run build",
        "build:www": "pnpm --filter @navifox/www run build",
        "build:docs": "pnpm --filter @navifox/docs run build",
        "preview:www": "pnpm --filter @navifox/www run preview --host",
        "preview:docs": "pnpm --filter @navifox/docs run preview --host",
        "repreview:www": "pnpm run build:www && pnpm run preview:www",
        "repreview:docs": "pnpm run build:docs && pnpm run preview:docs",
        "clean": "node ./scripts/clean.mjs",
        "reinstall": "pnpm run clean --del-lock && pnpm install"
    },
    "dependencies": {
    },
    "devDependencies": {
        "@types/node": "^24.10.8",
        "typescript": "~5.9.3"
    },
    "packageManager": "pnpm@10.28.0",
    "pnpm": {
        "overrides": {
            "vite": "npm:rolldown-vite@7.2.5"
        }
    }
}
