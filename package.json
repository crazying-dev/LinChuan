{
    "name": "navifox-pages",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "pnpm -r run build",
        "build:docs": "pnpm --filter @navifox/docs run build",
        "build:refs": "pnpm --filter @navifox/refs run build",
        "build:www": "pnpm --filter @navifox/www run build",
        "clean": "node ./scripts/clean.mjs",
        "dev:docs": "pnpm --filter @navifox/docs run dev --host",
        "dev:refs": "pnpm --filter @navifox/refs run dev --host",
        "dev:www": "pnpm --filter @navifox/www run dev --host",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "migrate": "codemod pnpm/catalog",
        "preview:docs": "pnpm --filter @navifox/docs run preview --host",
        "preview:refs": "pnpm --filter @navifox/refs run preview --host",
        "preview:www": "pnpm --filter @navifox/www run preview --host",
        "reinstall": "pnpm run clean --del-lock && pnpm install",
        "syncpack:fix": "syncpack fix && pnpm install",
        "syncpack:lint": "syncpack lint",
        "syncpack:list": "syncpack list",
        "taze:check": "taze --recursive",
        "taze:minor": "taze minor -w --recursive",
        "taze:patch": "taze patch -w --recursive",
        "typecheck": "pnpm -r run typecheck"
    },
    "devDependencies": {
        "@codemod.com/cli-win32-x64-msvc": "catalog:",
        "@navifox/tsconfig": "workspace:*",
        "@types/node": "catalog:",
        "codemod": "catalog:",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "syncpack": "catalog:",
        "taze": "catalog:",
        "typescript": "catalog:"
    },
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "11.11.0",
            "onFail": "error"
        },
        "runtime": {
            "name": "node",
            "version": ">=22.22.2",
            "onFail": "error"
        }
    }
}
