{
    "name": "navifox-pages",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev:home": "pnpm --filter @navifox/home run dev",
        "dev:docs": "pnpm --filter @navifox/docs run dev",
        "build": "pnpm -r run build",
        "build:home": "pnpm --filter @navifox/home run build",
        "build:docs": "pnpm --filter @navifox/docs run build",
        "preview:home": "pnpm --filter @navifox/home run preview",
        "preview:docs": "pnpm --filter @navifox/docs run preview",
        "repreview:home": "pnpm run build:home && pnpm run preview:home",
        "repreview:docs": "pnpm run build:docs && pnpm run preview:docs",
        "clean": "node ./scripts/clean.mjs",
        "reinstall": "pnpm run clean --del-lock && pnpm install"
    },
    "dependencies": {
    },
    "devDependencies": {
        "@types/node": "^24.10.8",
        "typescript": "~5.9.3"
    },
    "packageManager": "pnpm@10.28.0",
    "pnpm": {
        "overrides": {
            "vite": "npm:rolldown-vite@7.2.5"
        }
    }
}
